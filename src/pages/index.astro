---
import Base from '../layouts/Base.astro';
import HeroSim from '../components/HeroSim.astro';
import { AUTHOR, SOCIAL, CONTACT, HOME_POST_COUNT, HOME_PUBLICATION_COUNT, HOME_RESEARCH_COUNT } from '../config';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('post').catch(() => []))
  .filter((p: any) => !p.data.draft)
  .sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf());

const allPubs = (await getCollection('publications').catch(() => []))
  .filter((p: any) => !p.data.draft)
  .sort((a: any, b: any) => b.data.year - a.data.year);

const allProjects = (await getCollection('project').catch(() => []))
  .filter((p: any) => !p.data.draft)
  .sort((a: any, b: any) => (a.data.order ?? 99) - (b.data.order ?? 99));

const recentPosts   = allPosts.slice(0, HOME_POST_COUNT);
const recentPubs    = allPubs.slice(0, HOME_PUBLICATION_COUNT);
const featuredProjs = allProjects.slice(0, HOME_RESEARCH_COUNT);

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
function readTime(body: string) {
  return Math.max(1, Math.ceil((body?.split(/\s+/).length ?? 0) / 200));
}
---

<Base>

<!-- ══════════════════════════════════════════════════
     HERO — simulation + identity overlay
══════════════════════════════════════════════════ -->
<section id="about" class="hero-section">
  <HeroSim />

  <section class="hero-content">
    <h1>{AUTHOR.name}</h1>
    <p>{AUTHOR.title}</p>
    <p set:html={AUTHOR.bio} />
  </section>
</section>

<!-- ══════════════════════════════════════════════════
     POSTS
══════════════════════════════════════════════════ -->
<section id="posts" class="home-section">
  <div class="container">
    <h2 class="section-heading">Posts</h2>
    {recentPosts.length === 0 ? (
      <p class="empty-note">No posts yet. Create <code>src/content/post/my-first-post.mdx</code></p>
    ) : (
      <div class="post-list">
        {recentPosts.map((post: any) => (
          <a href={`/posts/${post.slug}/`} class="post-row fade-up">
            <div class="post-row-body">
              <h3 class="post-row-title">{post.data.title}</h3>
              {post.data.subtitle && <p class="post-row-subtitle">{post.data.subtitle}</p>}
              <div class="post-row-meta">
                <time>{fmtDate(post.data.date)}</time>
                <span class="meta-dot">·</span>
                <span>{post.data.readingTime ?? readTime(post.body ?? '')} min read</span>
              </div>
            </div>
            {post.data.image && (
              <img src={post.data.image} alt="" class="post-row-thumb" width="120" height="80" loading="lazy" />
            )}
          </a>
        ))}
      </div>
    )}
    {allPosts.length > HOME_POST_COUNT && (
      <div class="section-footer">
        <a href="/posts/" class="see-all-link">See all posts →</a>
      </div>
    )}
  </div>
</section>

<!-- ══════════════════════════════════════════════════
     PUBLICATIONS
══════════════════════════════════════════════════ -->
<section id="publications" class="home-section home-section--alt">
  <div class="container">
    <h2 class="section-heading">Publications</h2>
    {recentPubs.length === 0 ? (
      <p class="empty-note">No publications yet. Create <code>src/content/publications/my-paper.md</code></p>
    ) : (
      <div class="pub-list">
        {recentPubs.map((pub: any) => (
          <a href={`/publications/${pub.slug}/`} class="pub-row fade-up">
            <div class="pub-row-body">
              <h3 class="pub-row-title">{pub.data.title}</h3>
              <p class="pub-row-authors">
                {pub.data.authors.map((a: string, i: number, arr: string[]) => (
                  <span class:list={[{ 'author-self': a === AUTHOR.name }]}>
                    {a}{i < arr.length - 1 ? ', ' : ''}
                  </span>
                ))}
              </p>
              {pub.data.journal && (
                <p class="pub-row-journal">
                  <em>{pub.data.journal}</em>, {pub.data.year}
                  {pub.data.status !== 'published' && <span class="pub-status"> · {pub.data.status.replace('-', ' ')}</span>}
                </p>
              )}
              <div class="pub-row-links" onclick="event.preventDefault()">
                {pub.data.pdf    && <a href={pub.data.pdf}                              target="_blank" rel="noopener" class="pub-link" onclick="event.stopPropagation()">PDF</a>}
                {pub.data.slides && <a href={pub.data.slides}                           target="_blank" rel="noopener" class="pub-link" onclick="event.stopPropagation()">Slides</a>}
                {pub.data.arxiv  && <a href={`https://arxiv.org/abs/${pub.data.arxiv}`} target="_blank" rel="noopener" class="pub-link" onclick="event.stopPropagation()">arXiv</a>}
                {pub.data.doi    && <a href={`https://doi.org/${pub.data.doi}`}          target="_blank" rel="noopener" class="pub-link" onclick="event.stopPropagation()">DOI</a>}
                {pub.data.repo   && <a href={pub.data.repo}                              target="_blank" rel="noopener" class="pub-link" onclick="event.stopPropagation()">Code</a>}
              </div>
            </div>
            {pub.data.image && (
              <img src={pub.data.image} alt="" class="pub-row-thumb" width="120" height="80" loading="lazy" />
            )}
          </a>
        ))}
      </div>
    )}
    {allPubs.length > HOME_PUBLICATION_COUNT && (
      <div class="section-footer">
        <a href="/publications/" class="see-all-link">See all publications →</a>
      </div>
    )}
  </div>
</section>

<!-- ══════════════════════════════════════════════════
     RESEARCH
══════════════════════════════════════════════════ -->
<section id="research" class="home-section">
  <div class="container">
    <h2 class="section-heading">Research</h2>
    {featuredProjs.length === 0 ? (
      <p class="empty-note">No projects yet. Create <code>src/content/project/my-project.md</code></p>
    ) : (
      <div class="project-grid">
        {featuredProjs.map((proj: any) => (
          <a href={`/project/${proj.slug}/`} class="project-card fade-up">
            {proj.data.image && (
              <div class="project-card-img">
                <img src={proj.data.image} alt="" width="540" height="200" loading="lazy" />
              </div>
            )}
            <div class="project-card-body">
              <h3 class="project-card-title">{proj.data.title}</h3>
              <p class="project-card-desc">{proj.data.description}</p>
              <div class="project-card-links" onclick="event.preventDefault()">
                {proj.data.links.map((l: any) => (
                  <a href={l.href} target="_blank" rel="noopener" class="pub-link" onclick="event.stopPropagation()">{l.label}</a>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
    {allProjects.length > HOME_RESEARCH_COUNT && (
      <div class="section-footer">
        <a href="/project/" class="see-all-link">See all projects →</a>
      </div>
    )}
  </div>
</section>

<!-- ══════════════════════════════════════════════════
     CONTACT
══════════════════════════════════════════════════ -->
<section id="contact" class="home-section home-section--alt">
  <div class="container">
    <h2 class="section-heading">Contact</h2>
    <div class="contact-grid">
      <div class="contact-item">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span>{CONTACT.location}</span>
      </div>
      {CONTACT.office && (
        <div class="contact-item">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><path d="M8 21h8M12 17v4"/></svg>
          <span>{CONTACT.office}</span>
        </div>
      )}
      <div class="contact-item">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <a href={`mailto:${AUTHOR.email}`}>{AUTHOR.email}</a>
      </div>
    </div>
  </div>
</section>

</Base>

<style>
/* ── Hero overlay content ── */
.hero-content {
  text-align: center;
  padding: 2.5rem 1rem 1rem;
  max-width: 700px;
  margin: 0 auto;
}
.hero-name  {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  margin-bottom: 0.2rem;
  color: var(--text);
}
.hero-title { font-size: 0.95rem; color: var(--text-2); margin-bottom: 0.1rem; font-weight: 400; }
.hero-inst  { font-size: 0.82rem; color: var(--text-3); margin-bottom: 1rem; }
.hero-bio   {
  font-size: 0.9rem;
  color: var(--text-2);
  line-height: 1.65;
  margin-bottom: 1.25rem;
  max-width: 480px;
  margin-left: auto;
  margin-right: auto;
}
.hero-bio a { text-decoration: underline; text-underline-offset: 2px; color: var(--accent); }
.hero-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}
.hero-socials { display: flex; gap: 0.55rem; align-items: center; }
.social-icon {
  color: var(--text-3);
  display: flex;
  align-items: center;
  transition: color var(--t), transform var(--t);
}
.social-icon:hover { color: var(--accent); transform: translateY(-2px); }

/* ── Home sections ── */
.home-section     { padding: 3.5rem 0; background: var(--bg); }
.home-section--alt { background: var(--bg-off); }

.empty-note {
  color: var(--text-3); font-size: 0.9rem; padding: 2rem;
  border: 1px dashed var(--border-med); border-radius: var(--r-lg); text-align: center;
}
.section-footer { margin-top: 1.5rem; }
.see-all-link { font-size: 0.9rem; font-weight: 500; }

/* ── Post rows ── */
.post-list { display: flex; flex-direction: column; }
.post-row {
  display: flex; align-items: flex-start; justify-content: space-between;
  gap: 1.5rem; padding: 1.25rem 0.5rem;
  border-bottom: 1px solid var(--border);
  text-decoration: none !important; color: inherit;
  border-radius: var(--r); transition: background var(--t), padding var(--t);
}
.post-row:first-child { border-top: 1px solid var(--border); }
.post-row:hover { background: var(--bg-off); padding-left: 1rem; padding-right: 1rem; }
.post-row-body { flex: 1; min-width: 0; }
.post-row-title { font-size: 1rem; font-weight: 600; margin-bottom: 0.2rem; color: var(--text); transition: color var(--t); }
.post-row:hover .post-row-title { color: var(--accent); }
.post-row-subtitle {
  font-size: 0.875rem; color: var(--text-2); margin-bottom: 0.35rem;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.post-row-meta { font-size: 0.8rem; color: var(--text-3); display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
.meta-dot { opacity: 0.4; }
.post-row-thumb { width: 110px; height: 74px; object-fit: cover; border-radius: var(--r); flex-shrink: 0; border: 1px solid var(--border); }

/* ── Publication rows ── */
.pub-list { display: flex; flex-direction: column; }
.pub-row {
  display: flex; align-items: flex-start; justify-content: space-between;
  gap: 1.5rem; padding: 1.25rem 0.5rem;
  border-bottom: 1px solid var(--border);
  text-decoration: none !important; color: inherit;
  border-radius: var(--r); transition: background var(--t), padding var(--t);
}
.pub-row:first-child { border-top: 1px solid var(--border); }
.pub-row:hover { background: var(--bg-off); padding-left: 1rem; padding-right: 1rem; }
.pub-row-body { flex: 1; min-width: 0; }
.pub-row-title { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; color: var(--text); transition: color var(--t); }
.pub-row:hover .pub-row-title { color: var(--accent); }
.pub-row-authors { font-size: 0.84rem; color: var(--text-2); margin-bottom: 0.2rem; }
.author-self { font-weight: 700; color: var(--text); }
.pub-row-journal { font-size: 0.81rem; color: var(--text-3); margin-bottom: 0.35rem; }
.pub-status { color: var(--accent); font-style: normal; font-weight: 500; }
.pub-row-links { display: flex; gap: 0.35rem; flex-wrap: wrap; margin-top: 0.4rem; }
.pub-link {
  font-size: 0.77rem; font-weight: 500; color: var(--accent-hover);
  border: 1px solid var(--accent-border); background: var(--accent-light);
  padding: 0.15em 0.6em; border-radius: 4px; transition: background var(--t);
  text-decoration: none !important;
}
.pub-link:hover { background: var(--accent); color: var(--text-inv); }
.pub-row-thumb { width: 110px; height: 74px; object-fit: cover; border-radius: var(--r); flex-shrink: 0; border: 1px solid var(--border); }

/* ── Project grid ── */
.project-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1.25rem;
}
.project-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r-lg); overflow: hidden;
  text-decoration: none !important; color: inherit;
  display: flex; flex-direction: column;
  transition: border-color var(--t), box-shadow var(--t), transform var(--t-med);
}
.project-card:hover {
  border-color: var(--accent-dim);
  box-shadow: 0 6px 24px rgba(0,0,0,.09);
  transform: translateY(-3px);
}
.project-card:hover .project-card-title { color: var(--accent); }
.project-card-img { aspect-ratio: 16/7; overflow: hidden; background: var(--bg-subtle); }
.project-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--t-slow); }
.project-card:hover .project-card-img img { transform: scale(1.04); }
.project-card-body { padding: 1.1rem 1.25rem; flex: 1; display: flex; flex-direction: column; gap: 0.5rem; }
.project-card-title { font-size: 0.95rem; font-weight: 600; line-height: 1.3; transition: color var(--t); }
.project-card-desc  { font-size: 0.84rem; color: var(--text-2); line-height: 1.55; flex: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.project-card-links { display: flex; gap: 0.35rem; flex-wrap: wrap; }

/* ── Contact ── */
.contact-grid { display: flex; flex-direction: column; gap: 0.85rem; margin-top: 0.5rem; }
.contact-item { display: flex; align-items: center; gap: 0.75rem; font-size: 0.92rem; color: var(--text-2); }
.contact-item svg { flex-shrink: 0; color: var(--text-3); }
.contact-item a { color: var(--accent); }

/* ── Mobile ── */
@media (max-width: 680px) {
  .post-row-thumb, .pub-row-thumb { display: none; }
  .project-grid { grid-template-columns: 1fr; }
  .hero-bio { font-size: 0.85rem; }
}
</style>
