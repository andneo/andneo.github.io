---
import Base from '../layouts/Base.astro';
---
<Base title="404 — Not Found">
  <div class="not-found">
    <p class="code">404</p>
    <h1>Page not found</h1>
    <p>The page you're looking for doesn't exist or has moved.</p>
    <a href="/" class="btn btn-outline">Go home</a>
  </div>
</Base>
<style>
.not-found {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  min-height: 60vh; text-align: center; gap: 1rem; padding: 2rem;
}
.code { font-family: var(--font-mono); font-size: 5rem; font-weight: 700; color: var(--accent); opacity: 0.25; line-height: 1; }
.not-found h1 { font-size: 1.5rem; }
.not-found p { color: var(--text-2); font-size: 0.95rem; }
</style>
